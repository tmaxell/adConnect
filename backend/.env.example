# Copy to backend/.env and fill keys. backend/.env is gitignored — never commit keys.

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: gemini | groq | gigachat | ollama | anthropic
# If empty, the factory auto-selects the first provider with a key + installed package.
LLM_PROVIDER=gemini

# ── Google Gemini (recommended — generous free tier) ─────────────────────────
# Key: https://aistudio.google.com → Get API key
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# ── Groq (free tier) ──────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── GigaChat (Sber) ───────────────────────────────────────────────────────────
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_ALLOW_INSECURE_TLS=true

# ── Ollama (fully local, no key) ──────────────────────────────────────────────
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic Claude (paid) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Database ──────────────────────────────────────────────────────────────────
# Default: local SQLite at backend/data/adconnect_agents.sqlite3 (zero setup).
# Override with a full SQLAlchemy URL for Postgres, e.g.:
#   DATABASE_URL=postgresql+asyncpg://adconnect:adconnect@localhost:5432/adconnect
DATABASE_URL=
